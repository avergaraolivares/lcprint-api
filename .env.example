# ── Servidor ─────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── Base de datos ─────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=lcprint_web

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET=cambia_esto_por_un_secreto_seguro_min_32_chars
JWT_EXPIRES=24h

# ── Email (Gmail SMTP) ────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=tu_correo@gmail.com
MAIL_PASS=tu_app_password
MAIL_FROM=LC Print SpA <ventas@lcprint.cl>
MAIL_TO=ventas@lcprint.cl

# ── Archivos ──────────────────────────────────────────────────
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=5242880

# ── Frontend URL (para CORS) ──────────────────────────────────
FRONTEND_URL=http://localhost:5173
